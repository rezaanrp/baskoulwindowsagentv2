@page
@model ChangePasswordModel
@{
	ViewData["Title"] = "Change password";
	ViewData["ActivePage"] = ManageNavPages.ChangePassword;
	Layout = Model.Layout;

}
@section Style
	{

}

@section Body{
	<div class="row">
		<div class="col-4">
		</div>
		<div class="col-4">
			<div class="card card-primary">
				<div class="card-header">
					<h3 class="card-title">تغییر رمز عبور</h3>
				</div>
				<form id="change-password-form" method="post">
					<div class="card-body">
						<div asp-validation-summary="ModelOnly" class="text-danger"></div>
						<div class="form-floating">
							<input asp-for="Input.OldPassword" class="form-control" autocomplete="current-password" aria-required="true" />
							<label class="form-label">پسورد قدیمی</label>
							<span asp-validation-for="Input.OldPassword" class="text-danger"></span>
						</div>
						<div class="form-floating">
							<input asp-for="Input.NewPassword" class="form-control" autocomplete="new-password" aria-required="true" />
							<label class="form-label">پسورد جدید</label>
							<span asp-validation-for="Input.NewPassword" class="text-danger"></span>
						</div>
						<div class="form-floating">
							<input asp-for="Input.ConfirmPassword" class="form-control" autocomplete="new-password" aria-required="true" />
							<label class="form-label">تکرار پسورد جدید</label>
							<span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
						</div>
					</div>
					<!-- /.card-body -->

					<div class="card-footer">
						<button type="submit" class="btn btn-primary">ارسال</button>
					</div>
				</form>
			</div>
		</div>
		<div class="col-4">
		</div>
	</div>
	

	<partial name="_StatusMessage" for="StatusMessage" />

}



@section Scripts {
	<partial name="_ValidationScriptsPartial" />
}

