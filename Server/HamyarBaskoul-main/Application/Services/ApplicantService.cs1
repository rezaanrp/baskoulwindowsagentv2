using AutoMapper;
using Application.Interfaces;
using Application.ViewModels.Applicant;
using Domain.Interfaces;
using Domain.Models;

namespace Application.Services
{
    public class ApplicantService : IApplicantService
    {
        private readonly IApplicantRepository ApplicantRepository;
        private readonly IMapper mapper;
        public ApplicantService(IApplicantRepository ApplicantRepository, IMapper mapper)
        {
            this.ApplicantRepository = ApplicantRepository;
            this.mapper = mapper;
        }

        public bool DeleteAllApplicant()
        {
            return ApplicantRepository.DeleteAll();
        }

        public void DeleteApplicant(int Id)
        {
            ApplicantRepository.Delete(Id);
        }

        public IEnumerable<Applicant> GetAllApplicant()
        {
            var result = ApplicantRepository.GetAll();
            return result;
        }

        public ApplicantViewModel GetApplicantById(int Id)
        {
            var result = ApplicantRepository.GetById(Id);
            var result2 = mapper.Map<ApplicantViewModel>(result);
            return result2;
        }

        public Applicant GetApplicant(int Id)
        {
            var result = ApplicantRepository.GetById(Id);
            return result;
        }
        public void InsertApplicant(Applicant Applicant)
        {
           ApplicantRepository.Add(Applicant);
        }

        public void UpdateApplicant(Applicant Applicant)
        {
            ApplicantRepository.Update(Applicant);
        }
    }
}
