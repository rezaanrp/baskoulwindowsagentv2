@model Application.ViewModels.Users.SetPasswordViewModel
@{
	ViewData["Title"] = "ResetPassword";
	Layout = "~/Views/Shared/_LayoutAdminSimple.cshtml";
}
@section Style
	{

}

@section Body{
	<div class="row">
		<div class="col-4">
		</div>
		<div class="col-4">
			<div class="card card-primary">
				<div class="card-header">
					<h3 class="card-title">تغییر رمز عبور</h3>
				</div>
				<form id="change-password-form" asp-action="ResetUserPassword" asp-controller="UserManager" method="post">
				
					<div class="card-body">
						<div class="form-floating">
							<input asp-for="Password" class="form-control" autocomplete="new-password" aria-required="true" />
							<label class="form-label">پسورد جدید</label>
							<span asp-validation-for="Password" class="text-danger"></span>
						</div>
						<div class="form-floating">
							<input asp-for="RepeatePassword" class="form-control" autocomplete="new-password" aria-required="true" />
							<label class="form-label">تکرار پسورد جدید</label>
							<span asp-validation-for="RepeatePassword" class="text-danger"></span>
						</div>
					</div>
					<!-- /.card-body -->
					<input type="hidden" asp-for="Id" />
					<div class="card-footer">
						<button type="submit" class="btn btn-primary">ذخیره</button>
					</div>
				</form>
			</div>
		</div>
		<div class="col-4">
		</div>
	</div>


	

}
@section Scripts {
	
}

