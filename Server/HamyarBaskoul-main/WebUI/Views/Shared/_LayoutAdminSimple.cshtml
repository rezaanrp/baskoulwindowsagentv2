<!DOCTYPE html>
<html>
<head>
	<meta charset="utf-8">
	<meta http-equiv="X-UA-Compatible" content="IE=edge">

	<!-- Tell the browser to be responsive to screen width -->
	<meta name="viewport" content="width=device-width, initial-scale=1">
	<link href="~/apl/plugins/font-awesome/css/font-awesome.min.css" rel="stylesheet" />
	<!-- Font Awesome -->
	<!-- Ionicons -->
	<!-- DataTables -->
	<link href="~/apl/plugins/datatables/datatables.bootstrap4.css" rel="stylesheet" />
	<!-- Theme style -->
	<link rel="stylesheet" href="~/apl/dist/css/adminlte.css">
	<!-- Google Font: Source Sans Pro -->
	<!-- bootstrap rtl -->
	<link rel="stylesheet" href="~/apl/dist/css/bootstrap-rtl.min.css">
	<!-- template rtl version -->
	<link rel="stylesheet" href="~/apl/dist/css/custom-style.css">
	<link href="~/apl/plugins/select2/select2.min.css" rel="stylesheet" />
	
	<!-- AdminLTE for demo purposes -->
	<link href="~/css/loader.css" rel="stylesheet" />
	<style>
		.app-topbar {
			min-height: 58px;
			padding: 8px 14px;
		}

		.app-topbar-row {
			display: flex;
			align-items: center;
			justify-content: space-between;
			gap: 12px;
			width: 100%;
			min-width: 0;
		}

		.app-topbar-group {
			display: flex;
			align-items: center;
			gap: 8px;
			margin: 0;
			padding: 0;
			list-style: none;
			min-width: 0;
		}

		.app-topbar-link,
		.app-topbar-button {
			display: inline-flex !important;
			align-items: center;
			justify-content: center;
			gap: 7px;
			min-height: 38px;
			padding: 8px 12px !important;
			border-radius: 12px;
			color: #254038 !important;
			background: #f5faf8;
			border: 1px solid #e0ece7 !important;
			line-height: 1.4;
			white-space: nowrap;
			transition: background .2s ease, color .2s ease, border-color .2s ease, box-shadow .2s ease;
		}

		.app-topbar-link:hover,
		.app-topbar-button:hover {
			color: #0f7a5a !important;
			background: #edf8f4;
			border-color: rgba(15, 122, 90, .28) !important;
			box-shadow: 0 8px 18px rgba(15, 122, 90, .08);
			text-decoration: none;
		}

		.app-topbar-button {
			cursor: pointer;
			font: inherit;
		}

		.app-topbar-extra {
			margin-right: 8px;
		}

		@@media (max-width: 576px) {
			.app-topbar {
				padding: 8px;
			}

			.app-topbar-row {
				gap: 8px;
			}

			.app-topbar-group {
				gap: 6px;
			}

			.app-topbar-link,
			.app-topbar-button {
				width: 40px;
				height: 40px;
				min-height: 40px;
				padding: 0 !important;
				border-radius: 13px;
			}

			.app-topbar-text {
				display: none;
			}
		}
	</style>
	@RenderSection("Style", required: false)
</head>
<body class="sidebar-mini ">
	<div class="wrapper">
		<!-- Navbar -->
		<nav class="main-header navbar navbar-expand border-bottom navbar-light bg-white app-topbar">

			<!-- Left navbar links -->
			<div class="app-topbar-row">
				<!-- Left part -->
				<ul class="nav app-topbar-group">
					<li class="nav-item">
						<a class="nav-link app-topbar-link" data-widget="pushmenu" href="#" aria-label="باز و بسته کردن منو"><i class="fa fa-bars"></i></a>
					</li>
					<li class="nav-item">
                        <a asp-controller="Home" asp-action="Index" class="nav-link app-topbar-link"><span class="app-topbar-text">صفحه اصلی</span> <i class="fa fa-home"></i></a>
					</li>
				</ul>

@* 				<!-- Center part -->
				<div class="text-center">
					<h5 class="m-0">@await Component.InvokeAsync("CoName")</h5>
				</div> *@

				<!-- Right part -->
				<ul class="nav app-topbar-group">
					<li class="nav-item">
						<form asp-area="Identity" asp-page="/Account/Logout"
							  asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
							<button type="submit" class="nav-link btn app-topbar-button"><i class="fa fa-arrow-up"></i> <span class="app-topbar-text">خروج</span></button>
						</form>
					</li>
				</ul>
			</div>


			<ul class="navbar-nav mr-auto app-topbar-extra">
				<!-- Messages Dropdown Menu -->
				<li class="nav-item dropdown">

				</li>
				<!-- Notifications Dropdown Menu -->


				<li class="nav-item">
					<a class="nav-link app-topbar-link" data-widget="control-sidebar" data-slide="true" href="#" aria-label="پنل کناری"><i class="fa fa-th-large"></i></a>
				</li>
			</ul>
		</nav>
		<aside class=" main-sidebar sidebar-dark-primary elevation-4">
			<!-- Brand Logo -->
			<a href="#" class="brand-link" data-widget="pushmenu">
				<img src="~/apl/dist/img/logo1.png" alt="Logo" class="brand-image elevation-3" style="opacity: .8">
				<h5>
					پورتال نرم افزار سازمانی  
				</h5>
			</a>
			<!-- Sidebar -->
			<div class="sidebar">
				<div>
					<!-- Sidebar user panel (optional) -->
					<div class="user-panel mt-3 pb-3 mb-3 d-flex">
						<div class="image">
						</div>
						
						<div class="info">
							@RenderSection("ProfileName", required: false)
							<a href="#" class="d-block"> @await Component.InvokeAsync("UserName")   </a>
						</div>
					</div>

					<!-- Sidebar Menu -->
					<nav class="mt-2">
						<ul class="nav nav-pills nav-sidebar flex-column nav-child-indent" data-widget="treeview" role="menu" data-accordion="false">
							<!-- Add icons to the links using the .nav-icon class
								 with font-awesome or any other icon font library -->

							<li class="nav-item has-treeview menu-open">
								<a href="#" class="nav-link active">
									<i class="nav-icon fa fa-table"></i>
									<p>
										پنل کاربری
										<i class="fa fa-angle-left right"></i>
									</p>
								</a>
								@await Component.InvokeAsync("Menu")
							</li>
						</ul>
					</nav>
					<!-- /.sidebar-menu -->
				</div>
			</div>
			<!-- /.sidebar -->
		</aside>

		<!-- Content Wrapper. Contains page content -->
		<div class="content-wrapper">
			<!-- Content Header (Page header) -->
			<section class="content-header">
				<div class="container-fluid">
					<div class="row mb-2">
						<div class="col-sm-6">
							<h1> </h1>
						</div>
						<div class="col-sm-6">
							<ol class="breadcrumb float-sm-left">
						
							</ol>
						</div>
					</div>
				</div><!-- /.container-fluid -->
			</section>

			<!-- Main content -->

			<section class="content">
				<div class="container-fluid">
				@RenderSection("Body")

				</div>
			</section>
			<!-- /.content -->
		</div>
		<!-- /.content-wrapper -->
		<footer class="main-footer">
		</footer>
		<div class="loader-div">
			<img class="loader-img" src="~/image/zkz.gif" style="height: 120px;width: auto;" />
		</div>

	</div>
	<!-- ./wrapper -->
	<!-- jQuery -->
	<script src="~/apl/plugins/jquery/jquery.min.js"></script>
	<script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
	<script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>

@* 	<script src="~/apl/plugins/select2/select2.min.js"></script> *@
	<!-- Bootstrap 4 -->
	<script src="~/apl/plugins/bootstrap/js/bootstrap.bundle.min.js"></script>
	<!-- DataTables -->
	<script src="~/apl/plugins/datatables/jquery.dataTables.js"></script>
	<script src="~/apl/plugins/datatables/dataTables.bootstrap4.js"></script>
	<!-- SlimScroll -->
	<script src="~/apl/plugins/slimScroll/jquery.slimscroll.min.js"></script>

	<!-- FastClick -->
	<script src="~/apl/plugins/fastclick/fastclick.js"></script>
	<!-- AdminLTE App -->
	<script src="~/apl/dist/js/adminlte.min.js"></script>
	<!-- AdminLTE for demo purposes -->
	<script src="~/apl/dist/js/demo.js"></script>

	<script src="~/apl/plugins/select2/select2.full.min.js"></script>
@* 	<script>
		$.widget.bridge('uibutton', $.ui.button)
	</script> *@
	@RenderSection("Scripts", required: false)
	<script src="~/js/easy-number-separator.js"></script>
	<script>
		easyNumberSeparator({
			selector: '.number-separator',
			separator: ',',
			decimalSeparator: '.',

		})
	</script>
</body>
</html>

