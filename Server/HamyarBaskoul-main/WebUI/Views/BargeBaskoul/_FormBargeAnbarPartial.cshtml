<script>
    const interval = 10 * 60 * 1000; // 10 minutes in milliseconds
    const progressBar = document.getElementById("progressbar");

        function fetchAndUpdate() {
        fetch('@Url.Action("AutoUpdate", "APIs")')
            .then(response => response.json())
            .then(data => {
                // Check if result.state is true
                if (data.state === true) {
                    // Update progress bar
                    progressBar.value = 100;

                    // Optionally, reset it after a short moment
                    setTimeout(() => {
                        progressBar.value = 0;
                    }, 1000); // 1 second delay
                }

                // Update the label with message
                const label = document.getElementById("updateLabel");
                if (label && data.message) {
                    label.textContent = data.message;
                }
            })
            .catch(err => {
                alert("Error calling server:", err);
            });
    }

    function startUpdateCycle() {
        // Run immediately on load
        fetchAndUpdate();

        // Run every 10 minutes
        setInterval(fetchAndUpdate, interval);
    }

    // Start on page load
    window.addEventListener("load", startUpdateCycle);
</script>





