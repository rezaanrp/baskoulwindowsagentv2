using AutoMapper;
using Domain.Interfaces;
using Domain.Models;
using Infra.Data.Context;
using System;
using System.Collections.Generic;
using System.Linq;
using System.Text;
using System.Threading.Tasks;

namespace Infra.Data.Repository
{
    public class FilingUserRepository : IFilingUserRepository
    {
        private readonly CleanArchDataBaseContext _cleanArchDataBaseContext;
        private readonly IMapper _mapper;
        public FilingUserRepository(CleanArchDataBaseContext cleanArchDataBaseContext, IMapper mapper)
        {
            _cleanArchDataBaseContext = cleanArchDataBaseContext;
            _mapper = mapper;
        }

        public void Add(FilingUser applicants)
        {
            _cleanArchDataBaseContext.FilingUsers.Add(applicants);
            _cleanArchDataBaseContext.SaveChanges();
        }

        public void Delete(int Id)
        {
            //var applicants = _cleanArchDataBaseContext.FilingUsers.Find(Id);
            //_cleanArchDataBaseContext.FilingUsers.Remove(new FilingUser { Id = Id });
            //_cleanArchDataBaseContext.SaveChanges();

            var applicants = _cleanArchDataBaseContext.FilingUsers.Find(Id);
            if(applicants != null)
            {
                applicants.IsDeleted = true;
                _cleanArchDataBaseContext.SaveChanges();
            }
        }

        public bool DeleteAll()
        {
            try
            {
                var categories = _cleanArchDataBaseContext.FilingUsers.ToList();
                foreach (var applicants in categories)
                {
                    _cleanArchDataBaseContext.FilingUsers.Remove(applicants);
                    _cleanArchDataBaseContext.SaveChanges();
                }
                return true;
            }
            catch(Exception ex)
            {

            }
            return false;
        }

        public IEnumerable<FilingUser> GetAll()
        {
            var categories = _cleanArchDataBaseContext.FilingUsers.OrderByDescending(x => x.Id);
            return categories.AsEnumerable();
        }

        public FilingUser? GetById(int Id)
        {

            var applicants = _cleanArchDataBaseContext.FilingUsers.FirstOrDefault(x => x.Id == Id && (x.IsDeleted == false) );

            return applicants;
        }

        public void Update(FilingUser applicants)
        {
            var model = _cleanArchDataBaseContext.FilingUsers.Find(applicants.Id);
            if(model != null) 
            {
                model.Description = applicants.Description;
                model.Name = applicants.Name;
                model.IsDeleted = applicants.IsDeleted;   
                model.Id=applicants.Id;
                _cleanArchDataBaseContext.SaveChanges();
            }
        }
    }
}
