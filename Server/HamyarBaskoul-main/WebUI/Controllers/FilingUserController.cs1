		[HttpPost]
		public JsonResult load_data_users1()
		{
			int totalRecord = 0;
			int filterRecord = 0;

			var draw = Request.Form["draw"].FirstOrDefault();


			var sortColumn = Request.Form["columns[" + Request.Form["order[0][column]"].FirstOrDefault() + "][name]"].FirstOrDefault();


			var sortColumnDirection = Request.Form["order[0][dir]"].FirstOrDefault();


			var searchValue = Request.Form["search[value]"].FirstOrDefault();


			int pageSize = Convert.ToInt32(Request.Form["length"].FirstOrDefault() ?? "0");


			int skip = Convert.ToInt32(Request.Form["start"].FirstOrDefault() ?? "0");



			//  var data = _db.Set<SaleInfo>().AsQueryable();
			var data =  _filingUserService.GetAllFilingUser();

			//get total count of data in table
			totalRecord = data.Count();

			// search data when search value found
			if (!string.IsNullOrEmpty(searchValue))
			{
				data = data.Where(x =>
				  x.Mobile.ToLower().Contains(searchValue.ToLower())

				);
			}

			// get total count of records after search 
			filterRecord = data.Count();

			//sort data
			if (!string.IsNullOrEmpty(sortColumn) && !string.IsNullOrEmpty(sortColumnDirection))
			{
				if (sortColumnDirection == "asc")
				{
					var st = char.ToUpper(sortColumn[0]) + sortColumn.Substring(1);
					data = data.OrderBy(s => s.GetType().GetProperty(st).GetValue(s)).ToList();
				}
				else
				{
                    var st = char.ToUpper(sortColumn[0]) + sortColumn.Substring(1);
                    data = data.OrderByDescending(s => s.GetType().GetProperty(st).GetValue(s)).ToList();
                }
            }
			
			//data = data.OrderBy(sortColumn + " " + sortColumnDirection);


			//pagination
			var empList = data.Skip(skip).Take(pageSize).ToList();

			var returnObj = new { draw = draw, recordsTotal = totalRecord, recordsFiltered = filterRecord, data = empList };
			return Json(returnObj);

			//     return Json(data);
		}

		[HttpPost]
		public JsonResult load_data_users2(int id)
		{
			int totalRecord = 0;
			int filterRecord = 0;

			var draw = Request.Form["draw"].FirstOrDefault();


			var sortColumn = Request.Form["columns[" + Request.Form["order[0][column]"].FirstOrDefault() + "][name]"].FirstOrDefault();


			var sortColumnDirection = Request.Form["order[0][dir]"].FirstOrDefault();


			var searchValue = Request.Form["search[value]"].FirstOrDefault();


			int pageSize = Convert.ToInt32(Request.Form["length"].FirstOrDefault() ?? "0");


			int skip = Convert.ToInt32(Request.Form["start"].FirstOrDefault() ?? "0");



			var data = _filingUserDetailService.GetAllFilingByParentAndUser(id);

	
			totalRecord = data.Count();

			if (!string.IsNullOrEmpty(searchValue))
			{
			data =	data.Where(y => y.SerialFilingForm.Contains( searchValue) ).ToList();

			}

			filterRecord = data.Count();

			var empList = data.Skip(skip).Take(pageSize).ToList();

			var returnObj = new { draw = draw, recordsTotal = totalRecord, recordsFiltered = filterRecord, data = empList };
			return Json(returnObj);

		}
		[HttpGet]
		public IActionResult Insert()
        {
            var m = new FilingUserViewModel();
            //FilingUserService.InsertFilingUser(model);
            return View(m);
        }
		[HttpPost]
		public IActionResult Insert(FilingUserViewModel model)
		{

			var m = new FilingUser()
			{
				Name = model.Name,
				Family = model.Family,
				Mobile = model.Mobile,
				Tel = model.Tel,
				Description = model.Description,
				Supplier_ = OnGetUserId(),
                IsDeleted = false
			};

			_filingUserService.InsertFilingUser(m);
			return RedirectToAction("Index", "FilingUser");
		}

		[HttpGet]
        public IActionResult Edit(int id)
        {
            var result = _filingUserService.GetFilingUserById(id);
            //result.Id= id;
            return View(result);
        }

        [HttpPost]
        public IActionResult Edit(FilingUserViewModel model)
        {
            var result = _filingUserService.GetFilingUser(model.Id);
			result.Name = model.Name;
			result.Family = model.Family;
			result.Mobile = model.Mobile;
			result.Tel = model.Tel;

			result.Description = model.Description;

		_filingUserService.UpdateFilingUser(result);
			return RedirectToAction("Index", "FilingUser");

		}
