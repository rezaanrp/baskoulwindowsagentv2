using AutoMapper;
using Domain.Interfaces;
using Domain.Models;
using Infra.Data.Context;
using System;
using System.Collections.Generic;
using System.Linq;
using System.Text;
using System.Threading.Tasks;

namespace Infra.Data.Repository
{
    public class ApplicantRepository : IApplicantRepository
    {
        private readonly CleanArchDataBaseContext _cleanArchDataBaseContext;
        private readonly IMapper _mapper;
        public ApplicantRepository(CleanArchDataBaseContext cleanArchDataBaseContext, IMapper mapper)
        {
            _cleanArchDataBaseContext = cleanArchDataBaseContext;
            _mapper = mapper;
        }

        public void Add(Applicant applicants)
        {
            _cleanArchDataBaseContext.Applicants.Add(applicants);
            _cleanArchDataBaseContext.SaveChanges();
        }

        public void Delete(int Id)
        {
            //var applicants = _cleanArchDataBaseContext.Applicants.Find(Id);
            //_cleanArchDataBaseContext.Applicants.Remove(new Applicant { Id = Id });
            //_cleanArchDataBaseContext.SaveChanges();

            var applicants = _cleanArchDataBaseContext.Applicants.Find(Id);
            if(applicants != null)
            {
                applicants.IsDeleted = true;
                _cleanArchDataBaseContext.SaveChanges();
            }
        }

        public bool DeleteAll()
        {
            try
            {
                var categories = _cleanArchDataBaseContext.Applicants.ToList();
                foreach (var applicants in categories)
                {
                    _cleanArchDataBaseContext.Applicants.Remove(applicants);
                    _cleanArchDataBaseContext.SaveChanges();
                }
                return true;
            }
            catch(Exception ex)
            {

            }
            return false;
        }

        public IEnumerable<Applicant> GetAll()
        {
            var categories = _cleanArchDataBaseContext.Applicants.Where(x => x.IsDeleted == false).ToList();
            return categories.AsEnumerable();
        }

        public Applicant? GetById(int Id)
        {

            var applicants = _cleanArchDataBaseContext.Applicants.FirstOrDefault(x => x.Id == Id && (x.IsDeleted == false) );

            return applicants;
        }

        public void Update(Applicant applicants)
        {
            var model = _cleanArchDataBaseContext.Applicants.Find(applicants.Id);
            if(model != null) 
            {
                model.Description = applicants.Description;
                model.Name = applicants.Name;
                model.IsDeleted = applicants.IsDeleted;   
                model.Id=applicants.Id;
                _cleanArchDataBaseContext.SaveChanges();
            }
        }
    }
}
