@page
@model LoginModel

@{
    ViewData["Title"] = "ورود به سامانه";
    Layout = "~/Areas/Shared/_LoginLayout.cshtml";
}

<div class="auth-shell">
    <section class="auth-card" aria-label="فرم ورود">
        <div class="auth-brand">
            <div class="auth-logo-wrap">
                <img src="@Url.Content("~/APL/dist/img/logo2.png")" alt="لوگو" class="auth-logo" />
            </div>
            <div>
                <h1>ورود به سامانه همیار باسکول</h1>
                <p>برای ادامه، نام کاربری و رمز عبور خود را وارد کنید.</p>
            </div>
        </div>

        <form id="account" method="post" class="auth-form" novalidate>
            @if (TempData["LoginError"] != null)
            {
                <div class="auth-alert auth-alert-danger">
                    @TempData["LoginError"]
                </div>
            }

            <div asp-validation-summary="ModelOnly" class="auth-validation"></div>

            <label class="auth-field" asp-for="Input.Email">
                <span>نام کاربری</span>
                <input asp-for="Input.Email" autocomplete="username" aria-required="true" placeholder="نام کاربری" />
                <span asp-validation-for="Input.Email" class="auth-validation"></span>
            </label>

            <label class="auth-field" asp-for="Input.Password">
                <span>رمز عبور</span>
                <input asp-for="Input.Password" autocomplete="current-password" aria-required="true" placeholder="رمز عبور" />
                <span asp-validation-for="Input.Password" class="auth-validation"></span>
            </label>

            <label class="auth-remember" asp-for="Input.RememberMe">
                <input asp-for="Input.RememberMe" />
                <span class="auth-checkmark"></span>
                <span>مرا به خاطر بسپار</span>
            </label>

            <button type="submit" class="auth-submit">ورود</button>
        </form>
    </section>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

