@model Application.ViewModels.Reports.TripleReportViewModel

@{
    Layout = "~/Views/Shared/_LayoutAdminSimple.cshtml";
}

@section Style
{
    @{
    ViewData["Title"] = "چاپ سه‌نسخه‌ای برگه باسکول";
}

    @Html.Raw(@"
<style>
    @media print {
        @page {
            size: A4 portrait;
            margin: 10mm;
        }

        html, body {
            margin: 0;
            padding: 0;
            font-size: 15px;
            zoom: 0.85; /* Shrinks entire content */
        }

        .wrapper, .invoice {
            width: 100%;
            margin: 0 auto;
            padding: 0;
        }

        .card, .table {
            font-size: 11px;
        }

        h3, h4 {
            font-size: 16px;
            margin: 2px 0;
        }

        th, td {
            padding: 3px !important;
            font-size: 15px !important;
        }

        img {
            max-width: 70px;
            height: auto;
        }

        .row, .col-sm-3, .col-sm-5, .col-12 {
            margin: 0 !important;
            padding: 0 !important;
        }
    }
</style>
")
}

@section Body
{
    <body onload="window.print();">
        <div class="wrapper">
            <!-- Main content -->
            <!-- Main content -->
            <div class="invoice">
                <!-- title row -->
                <div class="row">
                    <div class="col-12 text-center">
                        <h3>
                            @Model.TypeBarge
                        </h3>
                        <h4>
                            @Model.CoName
                        </h4>
                    </div>
                    <!-- /.col -->
                </div>
                <!-- info row -->

                <div class="row invoice-info justify-content-center">
                    <div class="col-sm-3 text-end mx-2">
                        <img src=@Model.LogoPath alt="لوگو" style="max-width: 80px; height: 40px;" />
                    </div>
                    <div class="col-sm-3 invoice-col">
                        <b>
                            <strong>شماره قبض باسکول: @Model.GhabzBaskoul</strong>
                        </b>
                    </div>
                    <!-- /.col -->
                    <div class="col-sm-3 invoice-col">
                        <b>
                            <strong>تاریخ قبض: @Model.DateBarge</strong>
                        </b>
                    </div>
                    <!-- /.col -->
                    <div class="col-sm-3 invoice-col">
                        @if (Model.TypeBarge == "برگه باسکول ورود کالا")
                        {
                            <strong>تخلیه: @Model.IdTakhlie</strong>
                        }
                        else
                        {
                            <strong>بارگیری: @Model.IdBargiri</strong>
                        }
                    </div>
                </div>
                <hr />
                <div class="row invoice-info justify-content-center">
                    <div class="col-sm-3 invoice-col">
                        <b>
                            <strong>شماره سند: @Model.ShomareSanad</strong>
                        </b>
                    </div>
                    <!-- /.col -->
                    <div class="col-sm-3 invoice-col">
                        <b>
                            <strong>شماره بازنگری: @Model.BaznegariNumber</strong>
                        </b>
                    </div>
                    <!-- /.col -->
                    <div class="col-sm-3 invoice-col">
                        <strong>تاریخ بازنگری: @Model.BaznegariDate</strong>
                    </div>
                </div>
                <hr />
                <!-- /.row -->
                <div class="table-responsive">
                    <table border="1" dir="rtl" style="border-collapse: collapse; text-align: center; width: 100%;">
                        <thead>
                            <tr>
                                <th colspan="2">عنوان</th>
                                <th colspan="2">ساعت</th>
                                <th colspan="2">وزن KG</th>
                                <th colspan="2">وزن خالص</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td colspan="2">پر</td>
                                <td colspan="2">@Model.TimeVaznePor</td>
                                <td colspan="2">@Model.VaznPor</td>
                                <td rowspan="2" colspan="2">@Model.Vaznekhlaes</td>
                            </tr>
                            <tr>
                                <td colspan="2">خالی</td>
                                <td colspan="2">@Model.TimeVazneKhali</td>
                                <td colspan="2">@Model.VaznKhali</td>
                            </tr>
                            <tr>
                                <td colspan="1">نوع وسیله حمل</td>
                                <td colspan="2">@(string.IsNullOrEmpty(Model.Vasile) ? "-" : Model.Vasile)</td>
                                <td colspan="1">راننده</td>
                                <td colspan="2">@Model.NameRanande</td>
                                <td colspan="1">شماره ماشین</td>
                                <td colspan="1">@Model.ShomareMashin</td>
                            </tr>
                            <tr>
                                <td colspan="1">کالا</td>
                            <td colspan="3">@(string.IsNullOrEmpty(Model.Kala) ? "-" : Model.Kala)</td>
                                <td colspan="1">توضیحات</td>
                                <td colspan="3">@(Model.Tozihat == null ? "-" : Model.Tozihat)</td>
                            </tr>
                        </tbody>
                    </table>
                   
                </div>
                <div class="col-12 justify-content-center text-center mx-2">
                        <div class="card">
                            <table class="table">
                                <tr>
                                    <td>@Model.OfficeAdress</td>
                                </tr>
                                <tr>
                                    <td>@Model.FactoryAddress</td>
                                </tr>
                            </table>
                        </div>
                    </div>
                    <!-- /.col -->
                <hr />
                <div class="row justify-content-center text-center">
                    <div class="col-sm-5">
                        <b><strong>امضای راننده:</strong></b>
                    </div>
