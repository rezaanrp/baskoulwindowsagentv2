@model Application.ViewModels.Weighbridge.PagedResultBarge

@{
    Layout = "~/Views/Shared/_LayoutAdminSimple.cshtml";
}

@section Style
{
@{
    ViewData["Title"] = "لیست برگه‌های باسکول";
}

}

@section Body
{
    @if (!string.IsNullOrEmpty(ViewBag.ReportError))
    {
        <div class="alert text-danger">@ViewBag.ReportError</div>
    }
    @if (TempData["ReportError"] != null)
    {
        <script>alert('@Html.Raw(TempData["ReportError"])');</script>
    }
    <style>
        .clickable-row {
        cursor: pointer;
        }
    </style>
    <style>
        .table tbody tr:hover {
            background-color: #c3c2cc;
            cursor: pointer;
        }

        .table tbody tr {
            position: relative;
            z-index: 1;
        }

    </style>
    <div class="card card-outline card-info">
        <div class="card-header">
            <h3 class="card-title">برگه‌های باسکول</h3>
        </div>
        <div class="card-body">
            <div class="dataTables_wrapper dt-bootstrap4">
                <div class="row align-items-center">
                    <div class="input-group col-md-5 d-flex">
                        <input type="text" id="searchInput" class="form-control me-2" placeholder="جستجو بر اساس شماره قبض یا شماره ماشین">
                        <span class="input-group-append">
                            <button type="button" id="searchBtn" class="btn btn-info btn-flat">جست‌وجو</button>
                        </span>
                    </div>
                    <div class="col-md-2">
                        <select id="typeFilter" class="form-control mb-3">
                            <option value="">همه برگه‌ها</option>
                            <option value="1">ورود کالا</option>
                            <option value="2">خروج کالا</option>
                        </select>
                    </div>
                    <div class="col-md-5 d-flex">
                        <a class="btn btn-info open-modal _edit"
                           href="@Url.Action("BargeAnbar", "BargeBaskoul", new { type = 3 })"
                           title="ایجاد برگه ورود/خروج کالا" target="_blank">
                            ایجاد برگه ورود/خروج کالا
                        </a>
                        @* <a class="btn btn-icon open-modal btn-outline-primary btn-sm _edit"
                           href="@Url.Action("BargeAnbar", "BargeBaskoul", new { type = 3 })"
                           title="ایجاد برگه ورود/خروج کالا" target="_blank">
                            <img src="~/APL/dist/img/bargiri.png" alt="ایجاد برگه ورود/خروج کالا" style="width: 30px; height: 20px; object-fit: cover;">
                        </a> *@
@*                         <a class="btn btn-icon open-modal btn-outline-primary btn-sm _edit mx-2"
                           href="@Url.Action("BargeAnbar", "BargeBaskoul", new { type = 2 })"
                           title="ایجاد برگه خروج کالا" target="_blank">
                            <img src="~/APL/dist/img/takhlie.png" alt="ایجاد برگه خروج کالا" style="width: 20px; height: 20px; object-fit: cover;">
                        </a> *@
                    </div>
                </div>
                <div id="bargeTableContainer">
                    @Html.Partial("_BargeAnbarTable", Model)
                </div>
                
            </div>
        </div>
        <div class="card-footer">
        </div>
    </div>
}
@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            document.querySelectorAll(".clickable-row").forEach(row => {
                row.addEventListener("click", function () {
                    window.location = this.dataset.href;
                });
            });
        });
    </script>
<script>
        let currentSortColumn = '';
        let currentSortDirection = '';

        function loadFilteredData(page = 1, sortColumn = '', sortDirection = '') {
            var selectedType = $('#typeFilter').val();
            var searchTerm = $('#searchInput').val().trim();

            // If sortColumn not passed, use current values
            sortColumn = sortColumn || currentSortColumn;
            sortDirection = sortDirection || currentSortDirection;

            currentSortColumn = sortColumn;
            currentSortDirection = sortDirection;

              var url = '@Url.Action("ListBargeAnbar", "BargeBaskoul")' +
              '?type=' + selectedType +
              '&searchTerm=' + encodeURIComponent(searchTerm) +
              '&page=' + page;

            if (sortColumn) {
                url += '&sortColumn=' + sortColumn + '&sortDirection=' + sortDirection;
            }

            $.ajax({
                url: url,
                type: 'GET',
                success: function(response) {
                    $('#bargeTableContainer').html(response);

                    // Optional: Reset sortable headers
                    $('.sortable').data('order', 'asc');
                    if (sortColumn) {
                        $('.sortable[data-column="' + sortColumn + '"]').data('order', sortDirection);
                    }
                },
                error: function() {
                    alert('خطا در بارگیری داده‌ها.');
                }
            });
        }

        $(document).ready(function() {
            $('#typeFilter').on('change', function() { loadFilteredData(1); });
            $('#searchBtn').on('click', function() { loadFilteredData(1); });
            $('#searchInput').keypress(function(e) { if (e.which === 13) { loadFilteredData(1); return false; } });
            $(document).on('click', '.ajax-page-link', function(e) {
                e.preventDefault();
                var page = $(this).data('page') || $(this).text();
                loadFilteredData(page);
            });

            $(document).on('click', '.sortable', function() {
                var sortColumn = $(this).data('column');
                var newDirection = 'asc';
                if (currentSortColumn === sortColumn) {
                    newDirection = (currentSortDirection === 'asc') ? 'desc' : 'asc';
                }
                loadFilteredData(1, sortColumn, newDirection);
            });
        });
</script>
}




