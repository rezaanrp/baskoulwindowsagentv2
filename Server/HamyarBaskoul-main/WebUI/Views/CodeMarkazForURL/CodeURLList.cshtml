@using Application.ViewModels
@model PagedResultCodeMarkazList

@{
    ViewData["Title"] = "تنظیمات مراکز باسکول";
    Layout = "~/Views/Shared/_LayoutAdminSimple.cshtml";

    var markazesJson = System.Text.Json.JsonSerializer.Serialize(Model?.Markazes ?? new List<CodeMarkazViewModel>());
}

@section Style
{
    <style>
        [v-cloak] { display: none; }

        .markaz-page {
            --markaz-ink: #172d25;
            --markaz-muted: #687a74;
            --markaz-line: #dce9e3;
            --markaz-green: #0f7a5a;
            --markaz-green-dark: #084f3b;
            direction: rtl;
            display: grid;
            gap: 18px;
        }

        .markaz-hero,
        .markaz-toolbar,
        .markaz-card,
        .markaz-form-panel {
            border: 1px solid var(--markaz-line);
            background: #fff;
            box-shadow: 0 14px 36px rgba(18, 48, 39, .06);
        }

        .markaz-hero {
            overflow: hidden;
            border-radius: 26px;
            padding: 24px;
            color: var(--markaz-ink);
            background:
                radial-gradient(circle at 12% 14%, rgba(15, 122, 90, .18), transparent 22rem),
                linear-gradient(135deg, #ffffff 0%, #eef8f4 58%, #dfeee8 100%);
        }

        .markaz-hero h1 {
            margin: 0 0 8px;
            font-size: clamp(23px, 3vw, 34px);
            font-weight: 900;
        }

        .markaz-hero p {
            margin: 0;
            max-width: 780px;
            color: var(--markaz-muted);
            line-height: 2;
        }

        .markaz-toolbar {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 12px;
            flex-wrap: wrap;
            padding: 16px;
            border-radius: 22px;
        }

        .markaz-search {
            position: relative;
            flex: 1 1 300px;
            max-width: 520px;
        }

        .markaz-search i {
            position: absolute;
            top: 50%;
            inset-inline-start: 14px;
            color: var(--markaz-muted);
            transform: translateY(-50%);
        }

        .markaz-search input,
        .markaz-field input {
            width: 100%;
            min-height: 44px;
            padding: 10px 14px;
            border: 1px solid var(--markaz-line);
            border-radius: 15px;
            color: var(--markaz-ink);
            background: #fff;
            outline: none;
            transition: border-color .2s ease, box-shadow .2s ease;
        }

        .markaz-search input {
            padding-inline-start: 42px;
        }

        .markaz-search input:focus,
        .markaz-field input:focus {
            border-color: rgba(15, 122, 90, .45);
            box-shadow: 0 0 0 4px rgba(15, 122, 90, .10);
        }

        .markaz-add-btn,
        .markaz-submit-btn,
        .markaz-cancel-btn {
            min-height: 44px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            padding: 10px 16px;
            border-radius: 15px;
            border: 0;
            font-weight: 900;
            text-decoration: none;
        }

        .markaz-add-btn,
        .markaz-submit-btn {
            color: #fff;
            background: linear-gradient(135deg, var(--markaz-green), var(--markaz-green-dark));
            box-shadow: 0 12px 26px rgba(15, 122, 90, .22);
        }

        .markaz-cancel-btn {
            color: var(--markaz-ink);
            background: #f4f8f6;
            border: 1px solid var(--markaz-line);
        }

        .markaz-card,
        .markaz-form-panel {
            border-radius: 22px;
            overflow: hidden;
        }

        .markaz-table-wrap {
            overflow-x: auto;
        }

        .markaz-table {
            width: 100%;
            min-width: 860px;
            margin: 0;
            border-collapse: separate;
            border-spacing: 0;
        }

        .markaz-table th,
        .markaz-table td {
            padding: 14px 16px;
            vertical-align: middle;
            border-bottom: 1px solid #edf3f0;
            text-align: right;
        }

        .markaz-table th {
            color: var(--markaz-muted);
            background: #f8fbfa;
            font-size: 13px;
            font-weight: 900;
            white-space: nowrap;
        }

        .markaz-code {
            direction: ltr;
            display: inline-flex;
            padding: 5px 10px;
            border-radius: 999px;
            color: var(--markaz-green-dark);
            background: #eef8f4;
            font-weight: 900;
        }

        .markaz-url {
            direction: ltr;
            display: inline-block;
            max-width: 280px;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
            text-align: left;
            color: var(--markaz-ink);
        }

        .markaz-actions {
            display: inline-flex;
            align-items: center;
            gap: 7px;
            white-space: nowrap;
        }

        .markaz-action-btn {
            width: 36px;
            height: 36px;
            display: inline-grid;
            place-items: center;
            border-radius: 12px;
            border: 1px solid #d9e7e1;
            color: var(--markaz-green-dark);
            background: #fff;
            transition: transform .2s ease, background .2s ease, border-color .2s ease;
        }

        .markaz-action-btn:hover {
            transform: translateY(-2px);
            border-color: rgba(15, 122, 90, .35);
            background: #f0faf6;
        }

        .markaz-action-btn.danger {
            color: #b42318;
        }

        .markaz-action-btn.danger:hover {
            border-color: rgba(180, 35, 24, .28);
            background: #fff5f4;
        }

        .markaz-empty {
            padding: 34px 18px;
            color: var(--markaz-muted);
            text-align: center;
            line-height: 2;
        }

        .markaz-footer {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 12px;
            flex-wrap: wrap;
            padding: 14px 16px;
            color: var(--markaz-muted);
            background: #fbfefd;
        }

        .markaz-pagination {
            display: inline-flex;
            align-items: center;
            gap: 6px;
        }

        .markaz-page-btn {
            min-width: 36px;
            height: 36px;
            border-radius: 12px;
            border: 1px solid var(--markaz-line);
            color: var(--markaz-ink);
            background: #fff;
            font-weight: 800;
        }

        .markaz-page-btn:disabled {
            opacity: .45;
            cursor: not-allowed;
        }

        .markaz-page-btn.active {
            color: #fff;
            background: var(--markaz-green);
            border-color: var(--markaz-green);
        }

        .markaz-form-head {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 12px;
            padding: 16px 18px;
            background: #f8fbfa;
            border-bottom: 1px solid #edf3f0;
        }

        .markaz-form-head h2 {
            margin: 0;
            color: var(--markaz-ink);
            font-size: 19px;
            font-weight: 900;
        }

        .markaz-form {
            display: grid;
            gap: 18px;
            padding: 18px;
        }

        .markaz-form-grid {
            display: grid;
            grid-template-columns: repeat(4, minmax(0, 1fr));
            gap: 14px;
        }

        .markaz-field {
            display: grid;
            gap: 7px;
        }

        .markaz-field label {
            color: var(--markaz-ink);
            font-size: 13px;
            font-weight: 900;
        }

        .markaz-switch-row {
            display: flex;
            align-items: center;
            gap: 10px;
            min-height: 44px;
        }

        .markaz-switch-row input {
            width: 20px;
            height: 20px;
            accent-color: var(--markaz-green);
        }

        .markaz-form-actions {
            display: flex;
            justify-content: flex-end;
            gap: 10px;
            flex-wrap: wrap;
        }

        @@media (max-width: 991.98px) {
            .markaz-form-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
        }

        @@media (max-width: 575.98px) {
            .markaz-toolbar { align-items: stretch; flex-direction: column; }
            .markaz-search { max-width: none; }
            .markaz-add-btn { width: 100%; }
            .markaz-form-grid { grid-template-columns: 1fr; }
            .markaz-form-actions { flex-direction: column; }
            .markaz-form-actions button { width: 100%; }
        }
    </style>
}

@section Body
{
    <div id="codeMarkazApp" class="markaz-page" v-cloak>
        <section class="markaz-hero">
            <h1>تنظیمات مراکز باسکول</h1>
            <p>مرکزهای باسکول، کد مرکز، آدرس اتصال و آدرس API را از همین صفحه مدیریت کنید. افزودن و ویرایش بدون خروج از لیست انجام می‌شود.</p>
        </section>

        <section class="markaz-form-panel" v-if="form.visible">
            <div class="markaz-form-head">
                <h2>{{ form.mode === 'create' ? 'ایجاد مرکز جدید' : 'ویرایش مرکز باسکول' }}</h2>
                <button type="button" class="markaz-cancel-btn" v-on:click="closeForm">
                    <i class="fa fa-times"></i>
                    بستن فرم
                </button>
            </div>

            <form class="markaz-form" method="post" :action="form.mode === 'create' ? urls.insert : urls.edit">
                @Html.AntiForgeryToken()
                <input v-if="form.mode === 'edit'" type="hidden" name="Id" :value="form.model.id" />

                <div class="markaz-form-grid">
                    <div class="markaz-field">
                        <label>نام مرکز</label>
                        <input name="CoName" v-model.trim="form.model.coName" required />
                    </div>

                    <div class="markaz-field">
                        <label>کد مرکز</label>
                        <input name="CodMarkaz" v-model.trim="form.model.codMarkaz" required />
                    </div>

                    <div class="markaz-field">
                        <label>Connection URL</label>
                        <input name="MarkazURL" v-model.trim="form.model.markazURL" placeholder="مثال: irisa" />
                    </div>

                    <div class="markaz-field">
                        <label>API URL</label>
                        <input name="APIURL" v-model.trim="form.model.apiurl" dir="ltr" />
                    </div>

                    <div class="markaz-field">
                        <label>به‌روزرسانی خودکار</label>
                        <div class="markaz-switch-row">
                            <input type="checkbox" name="AutoAsync" value="true" v-model="form.model.autoAsync" />
                            <input type="hidden" name="AutoAsync" value="false" />
                            <span>{{ form.model.autoAsync ? 'فعال' : 'غیرفعال' }}</span>
                        </div>
                    </div>
                </div>

                <div class="markaz-form-actions">
                    <button type="submit" class="markaz-submit-btn">
                        <i class="fa fa-save"></i>
                        ذخیره
                    </button>
                    <button type="button" class="markaz-cancel-btn" v-on:click="closeForm">انصراف</button>
                </div>
            </form>
        </section>

        <section class="markaz-toolbar" aria-label="ابزارهای مدیریت مراکز">
            <div class="markaz-search">
                <i class="fa fa-search"></i>
                <input v-model.trim="search"
                       type="search"
                       autocomplete="off"
                       placeholder="جستجو بر اساس نام مرکز، کد مرکز یا آدرس" />
            </div>

            <button type="button" class="markaz-add-btn" v-on:click="openCreateForm">
                <i class="fa fa-plus"></i>
                <span>ایجاد مرکز جدید</span>
            </button>
        </section>

        <section class="markaz-card">
            <div class="markaz-table-wrap" v-if="pagedMarkazes.length">
                <table class="markaz-table">
                    <thead>
                        <tr>
                            <th>ردیف</th>
                            <th>نام مرکز</th>
                            <th>کد مرکز</th>
                            <th>Connection URL</th>
                            <th>API URL</th>
                            <th>به‌روزرسانی</th>
                            <th>عملیات</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr v-for="markaz in pagedMarkazes" :key="markaz.id">
                            <td>{{ markaz.id }}</td>
                            <td>{{ markaz.coName || '-' }}</td>
                            <td><span class="markaz-code">{{ markaz.codMarkaz || '-' }}</span></td>
                            <td><span class="markaz-url">{{ markaz.markazURL || '-' }}</span></td>
                            <td><span class="markaz-url">{{ markaz.apiurl || '-' }}</span></td>
                            <td>{{ markaz.autoAsync ? 'فعال' : 'غیرفعال' }}</td>
                            <td>
                                <div class="markaz-actions">
                                    <button type="button" class="markaz-action-btn" title="ویرایش" v-on:click="openEditForm(markaz)">
                                        <i class="fa fa-pencil"></i>
                                    </button>
                                    <button type="button" class="markaz-action-btn danger" title="حذف" v-on:click="confirmDelete(markaz)">
                                        <i class="fa fa-trash"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>

            <div v-else class="markaz-empty">
                مرکزی برای نمایش پیدا نشد.
            </div>

            <footer class="markaz-footer">
                <span>نمایش {{ pageStart }} تا {{ pageEnd }} از {{ filteredMarkazes.length }} مرکز</span>
                <div class="markaz-pagination" v-if="totalPages > 1">
                    <button type="button" class="markaz-page-btn" :disabled="page === 1" v-on:click="page--">&lt;</button>
                    <button type="button"
                            v-for="item in visiblePages"
                            :key="item"
                            class="markaz-page-btn"
                            :class="{ active: item === page }"
                            v-on:click="page = item">
                        {{ item }}
                    </button>
                    <button type="button" class="markaz-page-btn" :disabled="page === totalPages" v-on:click="page++">&gt;</button>
                </div>
            </footer>
        </section>

        <form ref="deleteForm" method="post" :action="urls.delete" class="d-none">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" :value="deleteId" />
        </form>
    </div>
}

@section Scripts
{
    <script src="@Url.Content("~/lib/vue/vue.global.prod.js")"></script>
    <script>
        (() => {
            const initialMarkazes = @Html.Raw(markazesJson);

            const normalizeMarkaz = (item) => ({
                id: item.Id ?? item.id ?? 0,
                codMarkaz: item.CodMarkaz ?? item.codMarkaz ?? '',
                markazURL: item.MarkazURL ?? item.markazURL ?? '',
                coName: item.CoName ?? item.coName ?? '',
                apiurl: item.APIURL ?? item.apiurl ?? '',
                autoAsync: Boolean(item.AutoAsync ?? item.autoAsync)
            });

            const emptyForm = () => ({
                id: 0,
                codMarkaz: '',
                markazURL: '',
                coName: '',
                apiurl: '',
                autoAsync: false
            });

            Vue.createApp({
                data() {
                    return {
                        markazes: initialMarkazes.map(normalizeMarkaz),
                        search: '',
                        page: 1,
                        pageSize: 10,
                        deleteId: 0,
                        form: {
                            visible: false,
                            mode: 'create',
                            model: emptyForm()
                        },
                        urls: {
                            insert: '@Url.Action("InsertURLMarkaz", "CodeMarkazForURL")',
                            edit: '@Url.Action("Edit", "CodeMarkazForURL")',
                            delete: '@Url.Action("Delete", "CodeMarkazForURL")'
                        }
                    };
                },
                computed: {
                    filteredMarkazes() {
                        const term = this.search.toLowerCase();
                        if (!term) return this.markazes;

                        return this.markazes.filter(markaz => [
                            markaz.coName,
                            markaz.codMarkaz,
                            markaz.markazURL,
                            markaz.apiurl
                        ].some(value => String(value || '').toLowerCase().includes(term)));
                    },
                    totalPages() {
                        return Math.max(1, Math.ceil(this.filteredMarkazes.length / this.pageSize));
                    },
                    pagedMarkazes() {
                        const start = (this.page - 1) * this.pageSize;
                        return this.filteredMarkazes.slice(start, start + this.pageSize);
                    },
                    pageStart() {
                        return this.filteredMarkazes.length ? ((this.page - 1) * this.pageSize) + 1 : 0;
                    },
                    pageEnd() {
                        return Math.min(this.page * this.pageSize, this.filteredMarkazes.length);
                    },
                    visiblePages() {
                        const pages = [];
                        const start = Math.max(1, this.page - 2);
                        const end = Math.min(this.totalPages, this.page + 2);
                        for (let item = start; item <= end; item++) pages.push(item);
                        return pages;
                    }
                },
                watch: {
                    search() { this.page = 1; },
                    filteredMarkazes() {
                        if (this.page > this.totalPages) this.page = this.totalPages;
                    }
                },
                methods: {
                    openCreateForm() {
                        this.form.mode = 'create';
                        this.form.model = emptyForm();
                        this.form.visible = true;
                        window.scrollTo({ top: 0, behavior: 'smooth' });
                    },
                    openEditForm(markaz) {
                        this.form.mode = 'edit';
                        this.form.model = { ...markaz };
                        this.form.visible = true;
                        window.scrollTo({ top: 0, behavior: 'smooth' });
                    },
                    closeForm() {
                        this.form.visible = false;
                    },
                    confirmDelete(markaz) {
                        if (!window.confirm(`آیا از حذف مرکز ${markaz.coName || ''} اطمینان دارید؟`)) {
                            return;
                        }

                        this.deleteId = markaz.id;
                        this.$nextTick(() => this.$refs.deleteForm.submit());
                    }
                }
            }).mount('#codeMarkazApp');
        })();
    </script>
}
