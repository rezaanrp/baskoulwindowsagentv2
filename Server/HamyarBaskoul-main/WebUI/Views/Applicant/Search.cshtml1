@using Application.ViewModels.Applicant;

@model ApplicantViewModel
@{
	ViewData["Title"] = "تغییر اطلاعات ";
	Layout = "~/Views/Shared/_LayoutAdminSimple.cshtml";

}
@section Style
	{

}
@section ProfileName
	{

}
@section Body{
	<div class="row">
		<div class="col-1">
		</div>
		<div class="col-10">

			<form id="change-password-form" method="post">
				<div class="card card-primary">
					<div class="card-header">
						<h3 class="card-title">مشخصات متقاضی</h3>
					</div>
					<div class="card-body">
						<div class="row">
							<div class="col-md-3">
								<div asp-validation-summary="ModelOnly" class="text-danger"></div>
								<div class="form-floating">
									<input asp-for="Name" class="form-control" aria-required="true" />
									<label class="form-label">نام</label>
									<span asp-validation-for="Name" class="text-danger"></span>
								</div>
							</div>
							<div class="col-md-3">
								<div class="form-floating">
									<input asp-for="Family" class="form-control" aria-required="true" />
									<label class="form-label">نام خانوادگی</label>
									<span asp-validation-for="Family" class="text-danger"></span>
								</div>
							</div>
							<div class="col-md-3">
								<div class="form-floating">
									<input asp-for="Mobile" class="form-control" aria-required="true" />
									<label class="form-label">تلفن همراه</label>
									<span asp-validation-for="Mobile" class="text-danger"></span>
								</div>
							</div>
							<div class="col-md-3">
								<div class="form-floating">
									<input asp-for="Tel" class="form-control" aria-required="true" />
									<label class="form-label">تلفن ثابت</label>
									<span asp-validation-for="Tel" class="text-danger"></span>
								</div>
							</div>
						</div>

					</div>
					<!-- /.card-body -->

				</div>

				<div class="card card-primary">

					<!-- /.card-body -->

					<div class="card-footer">
						<button type="submit" class="btn btn-primary">ارسال</button>
					</div>

				</div>
			</form>
		</div>
		<div class="col-1">
		</div>
	</div>
}
@section script {
	<partial name="_ValidationScriptsPartial" />
}
