@{
	ViewData["Title"] = "Home Page";
	Layout = "~/Views/Shared/_LayoutAdminSimple.cshtml";

}
@section Style
	{

}
@section ProfileName
	{

}
@section Body{
	<div class="row">
		<div class="col-1">
		</div>

		<div class="col-10">
			<div class="card card-primary">
				<div class="card-header">
					<h3 class="card-title"> لیست متقاضیان </h3>
				</div>
				<div class="card-body">
					<table id="users_table1" class="table table-bordered table-striped dataTable" style="width:100%">
						<thead>
							<tr>
								<th>نام </th>
								<th> نام خانوادگی</th>
								<th>شماره همراه</th>
								<th>شماره تلفن ثابت</th>
								<th width="200px">عملیات</th>
							</tr>
						</thead>
					</table>
				</div>
			</div>
		</div>

		<div class="col-1">
		</div>
	</div>
	<div class="row">
		<div class="col-1">
		</div>

		<div class="col-10">
			<div class="card card-primary">
				<div class="card-header">
					<h3 class="card-title">لیست تقاضا </h3>
				</div>
				<div class="card-body">
					<table id="users_table122" class="table table-bordered table-striped dataTable" style="width:100%">
						<thead>
							<tr>
								<th> کد </th>
								<th>تاریخ پذیرش </th>
								<th> کارشناس پذیرش </th>
								<th>ردیف متقاضی</th>
								<th>سریال فرم متقاضی</th>
								<th width="220px">عملیات</th>
							</tr>
						</thead>
					</table>
				</div>
			</div>
		</div>

		<div class="col-1">
		</div>
	</div>
}

@section script{
	<link href="~/apl/swat/sweetalert2.min.css" rel="stylesheet" />
	<script src="~/apl/swat/sweetalert2.all.min.js"></script>
	<script>
		var table;
		var table2;

		$(document).ready(function () {
			load_data();
		});
		$('body').on('click', '._edit', function () {
			var data = table.row($(this).parents('tr')).data();
			window.location.href = "/Applicant/Edit?id=" + data.id;
		});
		$('body').on('click', '._edit2', function () {
			var data = table2.row($(this).parents('tr')).data();
			window.location.href = "/ApplicantDetail/Edit?id=" + data.id;
		});
		$('body').on('click', '._Add', function () {
			var data = table.row($(this).parents('tr')).data();
			window.location.href = "/ApplicantDetail/Insert?id=" + data.id;
		});
		$('body').on('click', '._details', function () {
			 var data = table.row($(this).parents('tr')).data();
			// window.location.href = "/Applicant/Insert?id=" + data.id;
			load_data2(data.id);
		});
		$('body #users_table1').on('click', '._delete', function () {
			var data = table.row($(this).parents('tr')).data();

			Swal.fire({
				title: 'تایید عملیات',
				text: 'آیا از حذف آیتم انتخاب شده اطمینان دارید ؟',
				icon: "warning",
				showCancelButton: !0,
				confirmButtonText: "تایید",
				cancelButtonText: 'انصراف',
				customClass: {
					confirmButton: "btn btn-danger",
					cancelButton: "btn btn-outline-danger ms-1"
				},
				buttonsStyling: !1
			}).then((function (t) {
				if (t.isConfirmed) {
					_delete(data.id);

				} else {

				}
			}))
		});
		function _delete(id) {

			$.ajax({
				url: '/Applicant/DeleteUser?id=' + id,
				datatype: 'json',
				data: JSON.stringify(id),
				type: 'POST',
				contentType: 'application/json; charset=utf-8',
				success: function (response) {
					if (response.result) {
						toastr.success(response.msg, "تایید", {
							closeButton: !0,
							tapToDismiss: !1,
							showMethod: "slideDown",
							hideMethod: "slideUp",
							progressBar: !0,
							timeOut: 50e3,
							rtl: "rtl"
						})

					}
					else if (!response.result) {
						toastr.error(response.msg, "خطا", {
							closeButton: !0,
							tapToDismiss: !1,
							showMethod: "slideDown",
							hideMethod: "slideUp",
							progressBar: !0,
							timeOut: 50e3,
							rtl: "rtl"
						})
					}
					table.ajax.reload();
				},
				error: function (jqXHR, textStatus, errorThrown) {
					console.log('jqXHR:');
					console.log(jqXHR);
					console.log('textStatus:');
					console.log(textStatus);
					console.log('errorThrown:');
					console.log(errorThrown);
				}

			});
			Reload_data();
		}
		function Reload_data() {
			location.reload();

		}
		function load_data() {
			table = $('#users_table1').DataTable({
				"pageLength": 5,
				ajax: {
					url: "/Applicant/load_data_users1",
					datatype: 'json',
					type: 'POST',
				},
				"language": {
					"paginate": {
						"previous": "قبلی",
						"first": "صفحه اول",
						"next": "بعدی",
						"last": "آخرین صفحه"
					},
					"decimal": "",
					"emptyTable": "داده ای درجدول موجود نمی باشد",
					"info": "نمایش _START_ تا _END_ از _TOTAL_ رکورد",
					"infoEmpty": "نمایش 0 تا 0 از 0 رکوردها",
					"infoFiltered": "(filtered from _MAX_ total entries)",
					"infoPostFix": "",
					"thousands": ",",
					"lengthMenu": "نمایش _MENU_ رکورد",
					"loadingRecords": "...درحال بارگذاری",
					"processing": "درحال پردازش...",
					"search": "جستجو:",
					"zeroRecords": "هیچ رکوردی یافت نشد",
					"sLengthMenu": "نمایش _MENU_ رکورد",
				},
				columns: [
					{ data: "name", name: "name" },
					{ data: "family", name: "family" },
					{ data: "mobile", name: "mobile" },
					{ data: "tel", name: "tel" },
					{ data: null, "searchable": false, orderable: false, "autoWidth": true },
				],

				columnDefs: [
					{
						data: null,
						defaultContent: '<button type="button" class="btn btn-icon btn-outline-primary _details" style="margin-left: 2px;" title="جزئیات"><i class="fa fa-folder"></i></button>'
							+ '<button type="button" class="btn btn-icon btn-outline-warning _edit" style="margin-left: 2px;" title="ویرایش"><i class="fa fa-pencil"></i></button>'
							+ '<button type="button" class="btn btn-icon btn-outline-danger _delete" title="حذف"><i class="fa fa-trash"></i></button>'
									+ '<button type="button" class="btn btn-icon btn-outline-primary _Add" title="جدید"><i class="fa fa-plus"></i></button>',
						targets: -1
					}
				],
				processing: true,
				serverSide: true,
				paging: true,
				filter: true,
				ordering: false,

			});
		}
		function load_data2(id) {

			table2 =$('#users_table122').DataTable({
				destroy: true,
				paging: false,
				ajax: {
					url: "/Applicant/load_data_users2?id=" + id,
					datatype: 'json',
					type: 'POST',
				},
				"language": {
					"paginate": {
						"previous": "قبلی",
						"first": "صفحه اول",
						"next": "بعدی",
						"last": "آخرین صفحه"
					},
					"decimal": "",
					"emptyTable": "داده ای درجدول موجود نمی باشد",
					"info": "نمایش _START_ تا _END_ از _TOTAL_ رکورد",
					"infoEmpty": "نمایش 0 تا 0 از 0 رکوردها",
					"infoFiltered": "(filtered from _MAX_ total entries)",
					"infoPostFix": "",
					"thousands": ",",
					"lengthMenu": "نمایش _MENU_ رکورد",
					"loadingRecords": "...درحال بارگذاری",
					"processing": "درحال پردازش...",
					"search": "جستجو:",
					"zeroRecords": "هیچ رکوردی یافت نشد",
					"sLengthMenu": "نمایش _MENU_ رکورد",
				},
				columns: [
					{ data: "id", name: "id" },
					{ data: "datedmissionFarsi", name: "datedmission" },
					{ data: "admissionsSpecialistUser_", name: "admissionsSpecialistUser_" },
					{ data: "applicantRow", name: "applicantRow" },
					{ data: "applicantFormSerial", name: "applicantFormSerial" },
					{ data: null, "searchable": false, orderable: false, "autoWidth": true },
				],

				columnDefs: [
					{
						data: null,
						defaultContent:
							'<button type="button" class="btn btn-icon btn-outline-primary _edit2" style="margin-left: 2px;" title="ویرایش"><i class="fa fa-pencil"></i></button>'
							+ '<button type="button" class="btn btn-icon btn-outline-primary _delete2" title="حذف"><i class="fa fa-trash"></i></button>',
								targets: -1
					}
				],
				processing: true,
				serverSide: true,
				paging: true,
				filter: true,
				ordering: false,

			});
		}
	</script>

	<script>


	</script>
}

