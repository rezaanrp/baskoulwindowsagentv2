<script>
    const form = document.getElementById('form-anbar');
    const ranandeDropdown = document.getElementById('IDRanande');
    const ranandeInput = document.getElementById('OnvanRanandeh');

    const vanKhaliInput = document.getElementById('VanKhali');
    const vaznPorInput = document.getElementById('VaznPor');
    const shomareMashinInput = document.querySelector('input[name="ShomareMashin"]'); // Select by name

    form.addEventListener('submit', function (e) {
        const dropdownValue = ranandeDropdown.value.trim();
        const inputValue = ranandeInput.value.trim();

        const vanKhaliValue = vanKhaliInput.value.trim();
        const vaznPorValue = vaznPorInput.value.trim();
        const shomareMashinValue = shomareMashinInput.value.trim();

        if (dropdownValue === "" && inputValue === "") {
            alert('لطفاً راننده را انتخاب یا وارد کنید.');
            e.preventDefault();
        }

         // Check if both VanKhali and VaznPor are empty or zero
        if ((vanKhaliValue === "" || parseFloat(vanKhaliValue) === 0) &&
            (vaznPorValue === "" || parseFloat(vaznPorValue) === 0)) {
            alert('عملیات توزین برگه تکمیل نیست.');
            e.preventDefault();
            return;
        }

        // Check if ShomareMashin is empty
        if (shomareMashinValue === "") {
            alert('لطفاً شماره ماشین را وارد کنید.');
            e.preventDefault();
            return;
        }
    });
</script>
<script>
    document.addEventListener("DOMContentLoaded", function () {
        var toggleCheckbox = document.getElementById("toggleManualEntry");
        var textInput = document.querySelector(".RanandehInput input"); // اینجا فیلد ورودی متن راننده رو میگیریم
        var idHidden = document.getElementById("IDRanande"); // اینجا هم فیلد hidden یا select رو میگیریم (که در asp-for بود)

        function toggleFields() {
            if (toggleCheckbox.checked) {
                $(".RanandeDropdown").hide();
                $(".RanandehInput").show();
            } else {
                $(".RanandehInput").hide();
                $(".RanandeDropdown").show();
            }
        }

        toggleFields(); // آپدیت ظاهر فیلدها بر اساس وضعیت اولیه

        toggleCheckbox.addEventListener("change", function () {
            toggleFields();
        });

        // وقتی کاربر دستی تایپ می‌کند
        if (textInput) {
            textInput.addEventListener("input", function () {
                if (idHidden) {
                    idHidden.value = ""; // وقتی تایپ دستی می‌کند، ID پاک شود
                }
            });
        }
    });
</script>
<script>
    //خواندن وزن 
    document.addEventListener("DOMContentLoaded", function () {

        function getSelectedWeight() {

            let baskouls = document.querySelectorAll(".small-box");
            let selectedRadio = document.querySelector("input[name='selectedScale']:checked");

            let validBaskouls = [];

            baskouls.forEach(baskoul => {
                let weightElement = baskoul.querySelector("h3[id^='weight-']");
                let weight = parseFloat(weightElement.textContent) || 0;
                let type = baskoul.dataset.type; // Scale type

                if (weight > 0) {
                    validBaskouls.push({
                        element: baskoul,
                        weight: weight,
                        type: type
                    });
                }
            });

            // ❌ No valid weights
            if (validBaskouls.length === 0) {
                return 0;
            }

            // ✅ Only one scale → automatic
            if (validBaskouls.length === 1) {
                return validBaskouls[0].weight;
            }

            // ✅ If user selected a scale
            if (selectedRadio) {
                let selectedId = selectedRadio.value;
                let selected = validBaskouls.find(b =>
                    b.element.querySelector(`input[value='${selectedId}']`)
                );
                if (selected) return selected.weight;
            }

            // 🔍 No selection → decide based on VaznPor / VaznKhali
            let vaznPor = document.getElementById("VaznPor")?.value;
            let vaznKhali = document.getElementById("VanKhali")?.value;

            let targetType;

            if (vaznPor || vaznKhali) {
                targetType = "2";
            } else {
                targetType = "1";
            }

            let typeMatch = validBaskouls.find(b => b.type === targetType);

            if (typeMatch) {
                return typeMatch.weight;
            }

            // ❌ Type is null or not found
            alert("لطفاً باسکول مورد نظر را انتخاب کنید");
            return null;
        }

        // وزن پر
        document.getElementById("btnVaznPor").addEventListener("click", function (event) {
            event.preventDefault();
            let weight = getSelectedWeight();
            if (weight !== null) {
                document.getElementById("VaznPor").value = weight;
                document.getElementById("TimeVaznPor").value =
                    new Date().toLocaleTimeString("fa-IR");
            }
        });

        // وزن خالی
        document.getElementById("btnVaznKhali").addEventListener("click", function (event) {
            event.preventDefault();
            let weight = getSelectedWeight();
            if (weight !== null) {
                document.getElementById("VanKhali").value = weight;
                document.getElementById("TimeVaznKhali").value =
                    new Date().toLocaleTimeString("fa-IR");
            }
        });

    });
</script>
<script>
    document.addEventListener("DOMContentLoaded", function () {
        function calculateWeights() {
            const por = parseFloat(document.getElementById("VaznPor").value) || 0;
            const khali = parseFloat(document.getElementById("VanKhali").value) || 0;
            const basteBandi = parseFloat(document.getElementById("VaznBasteBandi")?.value) || 0; // Optional if not always present

            const ekhtelaf = por - khali;
            const khaalesh = ekhtelaf - basteBandi;

            document.getElementById("EkhtelafVazn").textContent = (ekhtelaf > 0 ? ekhtelaf.toLocaleString() : "--");
            document.getElementById("VaznKhaalesh").textContent = (khaalesh > 0 ? khaalesh.toLocaleString() : "--");
        }

        // Trigger calculation when any value changes
        document.getElementById("VaznPor").addEventListener("input", calculateWeights);
        document.getElementById("VanKhali").addEventListener("input", calculateWeights);

        // If your buttons fill values programmatically, trigger calculation after filling:
        document.getElementById("btnVaznPor").addEventListener("click", function () {
            setTimeout(calculateWeights, 200); // Wait a bit if async
        });

